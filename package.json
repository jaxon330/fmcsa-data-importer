{
  "name": "authority-history-importer",
  "version": "1.0.0",
  "description": "Standalone FMCSA authority history TXT importer",
  "main": "dist/scripts/importAuthorityHistory.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "db:migrate": "psql $DATABASE_URL -f migrations/001_create_fmcsa_authority_history.sql",
    "import:authority-history": "ts-node scripts/importAuthorityHistory.ts",
    "test": "jest --runInBand"
  },
