{
  "name": "fmcsa-data-importer",
  "version": "1.0.0",
  "description": "Standalone FMCSA data importer",
  "main": "dist/scripts/importFmcsa.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "db:migrate": "set -e; if [ -f .env ]; then set -a; . ./.env; set +a; fi; for f in migrations/*.sql; do psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f \"$f\"; done",
    "download:fmcsa": "ts-node src/scripts/downloadFmcsaFiles.ts",
    "import:fmcsa": "ts-node scripts/importFmcsa.ts",
    "import:fmcsa:batch": "ts-node src/scripts/importFmcsaBatch.ts",
    "sync:fmcsa": "ts-node src/scripts/syncFmcsa.ts",
    "import:authority-history": "ts-node scripts/importAuthorityHistory.ts",
    "test": "jest --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "dotenv": "^17.2.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
